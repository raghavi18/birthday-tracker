# ============================================================
# Birthday Tracker — Environment Variables Reference
# ============================================================
# Copy this file to .env for local development.
# Never commit .env — it is gitignored.
# ============================================================

# ------ Backend (set in Render dashboard for production) ------

# PostgreSQL connection string from your cloud database provider.
# If this is NOT set, the app falls back to SQLite (local dev only).
# Format (Supabase):  postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Format (Neon):      postgresql://[user]:[password]@[host]/[db]?sslmode=require
# Format (Render PG): postgresql://[user]:[password]@[host]:5432/[db]
DATABASE_URL=

# The GitHub Pages origin allowed by CORS.
# Default: https://raghavi18.github.io  (already set in render.yaml)
FRONTEND_URL=https://raghavi18.github.io

# Local dev overrides (optional):
# DB_PATH=/path/to/custom/birthdays.db
# BACKUP_DIR=/path/to/custom/backups
# PORT=5050
